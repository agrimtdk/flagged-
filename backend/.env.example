# Application Settings
ENV=development
DEBUG=true
PROJECT_NAME="flagged!"
VERSION=1.0.0
ALLOWED_ORIGINS=http://localhost,http://localhost:3000,http://127.0.0.1:3000

# Security Settings
JWT_SECRET=supersecretjwtkeyforhashingmustbechangedinproduction
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Google OAuth Settings
GOOGLE_CLIENT_ID=placeholder-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=placeholder-google-client-secret

# Database Settings (PostgreSQL)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=flagged_user
POSTGRES_PASSWORD=flagged_secure_password
POSTGRES_DB=flagged_db

# Caching & Rate Limiting (Redis)
REDIS_URL=redis://redis:6379/0

# Machine Learning Settings
MODEL_PATH=app/models/v1.0.2/model.json
DECISION_THRESHOLD=0.32
