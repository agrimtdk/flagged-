# Application Environment Configuration Example
# Copy this file to .env and replace placeholder values with your actual configuration.

# Core Environment
ENV=production
DEBUG=false
PROJECT_NAME="flagged!"
VERSION="1.0.0"

# PostgreSQL Database Configuration
POSTGRES_HOST=postgres.example.internal
POSTGRES_PORT=5432
POSTGRES_USER=db_user_example
POSTGRES_PASSWORD=replace_with_secure_password
POSTGRES_DB=flagged_db

# Redis Caching Layer Configuration
REDIS_URL=redis://redis.example.internal:6379/0

# Security & Authentication
JWT_SECRET=replace_with_64_character_cryptographic_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Allowed Origins
ALLOWED_ORIGINS=https://app.example.com,https://api.example.com

# Machine Learning Engine Paths
ML_ARTIFACT_DIR=/app/ml/artifacts
